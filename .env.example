# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
HOST=localhost

# ============================================
# DATABASE (XAMPP MySQL) bisa diganti sesuai kebutuhan
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=animacloud_db

# ============================================
# ANILIST API
# ============================================
ANILIST_API_URL=https://graphql.anilist.co
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
ANILIST_REDIRECT_URI=http://localhost:3000/api/v1/anilist/callback

# ============================================
# REDIS (Cache - Opsional)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# ============================================
# CORS
# ============================================
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# ============================================
# SYNC CONFIG
# ============================================
SYNC_BATCH_SIZE=10
SYNC_DELAY_MS=500
SYNC_MAX_RETRIES=3